# Copy this file to .env and fill in your values.

# The Gentry Commerce platform base URL.
# IMPORTANT: always set this to https://gentrycommerce.com — do NOT include your
# store slug (e.g. /my-store). The API key below scopes every request to your store.
VITE_STORE_URL=https://gentrycommerce.com

# Your headless API key.
# Find it in your admin panel → Integrations → Access & Headless API.
VITE_STORE_API_KEY=your-api-key-here
