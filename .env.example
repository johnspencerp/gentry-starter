# Copy this file to .env and fill in your values

# The base URL of your Gentry Commerce platform
VITE_STORE_URL=https://gentrycommerce.com

# Your store API key — find it in Admin > Settings > API
VITE_STORE_API_KEY=your-api-key-here

# Your store's slug (used for store name display, optional)
VITE_STORE_SLUG=your-store-slug
